{
  "name": "mcplint-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @mcplint/web dev",
    "mcplint": "pnpm --filter mcplint exec tsx src/cli.ts"
  }
}
