# Neon Postgres. Unset locally → runs are kept in memory and vanish on restart.
DATABASE_URL=

# Upstash Redis (rate limiting). Unset locally → limiting disabled.
# Required in production: without it, `mode: "url"` is a traffic amplifier.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog. Unset → no analytics network traffic at all.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Salt for hashing client IPs before they touch the database. Set to a random
# string in production — we never store a raw IP.
IP_HASH_SALT=

# Shared secret for the Vercel cron that purges expired reports.
CRON_SECRET=

# The paid-tier gate. "true" withholds findings and shows scores only.
# Leave false — v1 ships the full audit to everyone.
GATE_FINDINGS=false
